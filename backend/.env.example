# Flask Configuration
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=True

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data
DATA_PATH=../data

# AWS Configuration
# Use AWS CLI profiles - DO NOT put access keys here
AWS_REGION=us-east-1
AWS_PROFILE=dev  # or 'default' - configured via 'aws configure'

# NEVER put these in .env:
# AWS_ACCESS_KEY_ID=xxx  # ❌ NEVER
# AWS_SECRET_ACCESS_KEY=xxx  # ❌ NEVER

# Neptune (Phase 3)
NEPTUNE_ENDPOINT=
NEPTUNE_PORT=8182

# Bedrock (Phase 3)
BEDROCK_AGENT_ID=
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# SageMaker (Phase 3)
SAGEMAKER_ENDPOINT=chronos-forecast-endpoint

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
